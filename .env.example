# DataHub Graph Metadata Service endpoint.
DATAHUB_GMS_URL=http://localhost:8080

# Use a real personal access token when authentication is enabled.
# For an auth-disabled local quickstart, set an explicit non-secret placeholder.
DATAHUB_GMS_TOKEN=replace-with-datahub-token

# Official DataHub MCP server launcher.
DATAHUB_MCP_COMMAND=uvx
DATAHUB_MCP_ARGS=mcp-server-datahub
DATAHUB_MCP_TIMEOUT_SECONDS=30
